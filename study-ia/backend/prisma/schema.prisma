generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String?
  studyMethod   String    @default("hibrido")
  level         String    @default("intermedio")
  learningStyle String    @default("practico")
  wantsExamples Boolean   @default(true)
  detailLevel   String    @default("moderado")
  objective     String?
  onboardingDone Boolean   @default(false)
  
  grado         String?   @default("8")
  area          String?   @default("cientifico")
  areasInteres String?   @default("[]")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  documents     Document[]
  flashcards    Flashcard[]
  studySessions StudySession[]
  
  @@map("users")
}

model Document {
  id          String   @id @default(uuid())
  userId      String
  title       String
  content     String
  summary     String?
  keyPoints   String[] @default([])
  sourceType  String   @default("text")
  sourceUrl   String?
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards  Flashcard[]
  
  @@index([userId])
  @@map("documents")
}

model Flashcard {
  id          String   @id @default(uuid())
  userId      String
  documentId  String?
  front       String
  back        String
  tags        String[] @default([])
  difficulty  Int      @default(0)
  easeFactor  Float    @default(2.5)
  interval    Int      @default(1)
  nextReview  DateTime @default(now())
  repetitions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  reviews     Review[]
  
  @@index([userId])
  @@index([nextReview])
  @@map("flashcards")
}

model Review {
  id          String   @id @default(uuid())
  flashcardId String
  quality     Int
  responseTime Int?
  createdAt   DateTime @default(now())
  
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  
  @@index([flashcardId])
  @@map("reviews")
}

model StudySession {
  id          String   @id @default(uuid())
  userId      String
  topic       String
  duration    Int
  cardsStudied Int     @default(0)
  cardsLearned Int     @default(0)
  accuracy    Float    @default(0)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("study_sessions")
}

model QA {
  id          String   @id @default(uuid())
  userId      String
  documentId  String?
  question    String
  answer      String
  confidence  Float?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@map("qas")
}
