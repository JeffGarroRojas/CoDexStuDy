{
    "plataformas": {
        "base_de_datos": "Neon.tech",
        "backend": "Railway.app",
        "frontend": "Vercel.com"
    },
    "variables_entorno": {
        "servidor_railway": [
            {
                "key": "DATABASE_URL",
                "descripcion": "URL de conexión de Neon (CON pooler)",
                "ejemplo": "postgresql://user:pass@ep-cool-darkness-pooler.us-east-2.aws.neon.tech/neondb"
            },
            {
                "key": "DIRECT_URL",
                "descripcion": "URL de conexión directa de Neon (SIN pooler) para migraciones",
                "ejemplo": "postgresql://user:pass@ep-cool-darkness.us-east-2.aws.neon.tech/neondb"
            },
            {
                "key": "JWT_SECRET",
                "descripcion": "Token de 64 caracteres generado en ADAMAN",
                "valor_actual": "pJ5dOiWk5jSTuyJH8fwSHoE225OGI0ddFJEsWA0K5nM9sIj4gsGCnQkD87rFtxqW"
            },
            {
                "key": "GROQ_API_KEY",
                "descripcion": "Credencial para el motor de IA Groq",
                "ejemplo": "gsk_xxxx..."
            },
            {
                "key": "NODE_ENV",
                "valor": "production"
            }
        ],
        "interfaz_vercel": [
            {
                "key": "NEXT_PUBLIC_API_URL",
                "descripcion": "Link de tu backend en Railway + /api",
                "ejemplo": "https://api-codexstudy.up.railway.app/api"
            },
            {
                "key": "NEXTAUTH_SECRET",
                "descripcion": "Secreto para NextAuth (puedes usar el mismo JWT_SECRET)",
                "valor": "pJ5dOiWk5jSTuyJH8fwSHoE225OGI0ddFJEsWA0K5nM9sIj4gsGCnQkD87rFtxqW"
            },
            {
                "key": "NEXTAUTH_URL",
                "descripcion": "URL pública de tu frontend en Vercel",
                "ejemplo": "https://codexstudy.vercel.app"
            }
        ]
    },
    "comandos_finales": {
        "migracion_db": "npx prisma migrate deploy",
        "build_local": "npm run build"
    }
}