{
  "name": "codexstudy-backend",
  "version": "1.0.0",
  "description": "Backend API for CoDexStuDy - AI-powered study assistant",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && npx prisma@5.22.0 generate",
    "start": "npx prisma@5.22.0 db push && node dist/server.js",
    "serve": "node dist/server.js",
    "prisma:generate": "npx prisma@5.22.0 generate",
    "prisma:migrate": "npx prisma@5.22.0 migrate dev",
    "prisma:push": "npx prisma@5.22.0 db push",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:seed": "ts-node prisma/seed.ts",
    "postinstall": "npx prisma@5.22.0 generate"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pdfjs-dist": "^4.4.168",
    "pg": "^8.20.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": "20.x"
  }
}